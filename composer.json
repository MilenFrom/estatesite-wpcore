{
    "name": "milenfrom/estatesite-wpcore",
    "description": "EstateSite Core — real estate property management for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        { "name": "Estate Site", "homepage": "https://estatesite.eu" }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "EstateSite\\Core\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EstateSite\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    }
}
